<?xml version="1.0" encoding="UTF-8"?>
<ivysettings>
    <settings defaultResolver="default-chain"/>
    <property name="nexus-snapshots" value="https://central.sonatype.com/repository/maven-snapshots/"/>
    <property name="nexus-staging" value="https://ossrh-staging-api.central.sonatype.com/service/local/staging/deploy/maven2/"/>
    <property name="nexus-releases" value="http://localhost:8081/nexus/content/repositories/releases"/>
    <property name="nexus-public" value="http://localhost:8081/nexus/content/groups/public"/>
    <resolvers>
        <filesystem name="local">
            <ivy pattern="${ivy.default.ivy.user.dir}/local/[organisation]/[module]/[revision]/poms/[module].pom"/>
            <artifact pattern="${ivy.default.ivy.user.dir}/local/[organisation]/[module]/[revision]/[type]s/[module](-[classifier]).[ext]"/>
        </filesystem>
        <ibiblio name="ibiblio" m2compatible="true"/>

        <ibiblio name="nexus-snapshots" m2compatible="true" root="${nexus-snapshots}"/>
        <ibiblio name="nexus-staging" m2compatible="true" root="${nexus-staging}"/>
        <ibiblio name="nexus-releases" m2compatible="true" root="${nexus-releases}"/>
        <ibiblio name="nexus" m2compatible="true" root="${nexus-public}"/>

        <chain name="default-chain">
            <resolver ref="local"/>
            <resolver ref="nexus-snapshots"/>
            <resolver ref="ibiblio"/>
        </chain>
    </resolvers>
</ivysettings>
